setcpm(35)
var ch1 = `<
 [-2,0,2] [[-2,1,3] [-2,0,2]]
 [-3,-1,1] [[-3,0,2] [-3,-1,1]]
 [-4,-2,0] [-4#,-2,0]
 [-3,-1,1]@2
>`
var ch2 = `<
 [0,3,5] [[0,3,5#] [0,3,5]]
 [0,2,4] [[0,3,5] [0#,2,4]]
 [-2#,1,3] [-1,1,3] 
 [0,2,4]@2
>`

var M=1;
$: arrange(
  [0*8,stack(
    n(ch1).s("piano").scale("c3:major"),        
  )],
  [M*8,stack(
    n(ch2).s("piano").scale("c3:major"),    
  )],
) 